{
  "entities": {
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "type": "object",
      "description": "Represents a room where players can participate in an IPL auction.",
      "properties": {
        "roomCode": {
          "type": "string",
          "description": "Unique code for joining the room."
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to User who created the room."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the room was created.",
          "format": "date-time"
        },
        "phase": {
            "type": "string",
            "enum": ["lobby", "team-selection", "auction", "results"]
        },
        "auctionTimerDuration": {
            "type": "number",
            "description": "Default bidding timer duration in seconds, set at room creation."
        },
        "teams": {
            "type": "array",
            "items": { "$ref": "#/entities/Team" }
        },
        "squads": { "type": "object" },
        "playerPool": {
            "type": "array",
            "items": { "$ref": "#/entities/Player" }
        },
        "auction": {
            "type": "object",
            "properties": {
                "currentPlayerIndex": { "type": "number" },
                "timer": { "type": "number" },
                "currentBid": { "type": "number" },
                "highestBidder": { "type": "string" },
                "isPaused": { "type": "boolean" },
                "auctionTimerDuration": {
                    "type": "number",
                    "description": "Current bidding timer duration, adjustable during the auction."
                }
            }
        }
      },
      "required": [
        "roomCode",
        "ownerId",
        "createdAt",
        "phase"
      ]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user participating in the IPL auction game.",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "Display name of the user."
        },
        "isRoomOwner": {
          "type": "boolean",
          "description": "Whether the user is the owner of the room."
        }
      },
      "required": [ "displayName" ]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents an IPL team selected by a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "ownerId": {
          "type": "string",
          "description": "Reference to the User who owns the team."
        }
      },
      "required": [ "id", "name" ]
    },
    "Player": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Player",
      "type": "object",
      "description": "Represents a cricketer available for auction.",
      "properties": {
        "id": {
          "type": "number"
        },
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "nationality": {
          "type": "string"
        },
        "basePrice": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "role",
        "basePrice",
        "nationality"
      ]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "description": "A chat message within a room.",
      "properties": {
        "text": { "type": "string" },
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["user", "system"] },
        "teamName": { "type": "string", "description": "For system messages related to team selection." },
        "teamId": { "type": "string", "description": "The ID of the team associated with a system message." }
      },
      "required": ["text", "userId", "displayName", "createdAt", "type"]
    }
  },
  "auth": {
    "providers": [
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/rooms/{roomId}",
        "definition": {
          "entityName": "Room",
          "schema": {
            "$ref": "#/entities/Room"
          },
          "description": "Stores all data for a single game room."
        }
      },
      {
        "path": "/rooms/{roomId}/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/entities/User"
          },
          "description": "Stores users who have joined a specific room."
        }
      },
      {
        "path": "/rooms/{roomId}/messages",
        "definition": {
          "entityName": "Message",
          "schema": {
            "$ref": "#/entities/Message"
          },
          "description": "Stores chat messages for a specific room."
        }
      },
      {
        "path": "/players",
        "definition": {
            "entityName": "Player",
            "schema": {
                "$ref": "#/entities/Player"
            },
            "description": "Global list of available players."
        }
      }
    ]
  }
}
